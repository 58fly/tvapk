<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#FFFF5A5F" />
            <stroke
                android:width="1dp"
                android:color="#FFFFD7D9" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#FFB82A2A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#CC4A1718" />
            <stroke
                android:width="1dp"
                android:color="#88FF8A8A" />
        </shape>
    </item>
</selector>
