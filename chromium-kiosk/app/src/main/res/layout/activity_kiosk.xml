<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/webContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="15dp"
        android:paddingTop="3dp"
        android:paddingEnd="15dp">

        <Button
            android:id="@+id/refresh"
            android:layout_width="54dp"
            android:layout_height="31dp"
            android:background="@drawable/bkg_button_web"
            android:text="@string/action_refresh"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/zoomOut"
            android:layout_width="39dp"
            android:layout_height="31dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bkg_button_web"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/zoomLevel"
            android:layout_width="72dp"
            android:layout_height="31dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/bkg_button_web"
            android:gravity="center"
            android:singleLine="true"
            android:text="100%"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/zoomIn"
            android:layout_width="39dp"
            android:layout_height="31dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/bkg_button_web"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/urlText"
            android:layout_width="0dp"
            android:layout_height="31dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_button_web"
            android:ellipsize="middle"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <Button
            android:id="@+id/settings"
            android:layout_width="54dp"
            android:layout_height="31dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bkg_button_web"
            android:text="@string/action_settings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/exit"
            android:layout_width="54dp"
            android:layout_height="31dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bkg_button_web"
            android:text="@string/action_exit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CCB00020"
        android:paddingStart="32dp"
        android:paddingTop="24dp"
        android:paddingEnd="32dp"
        android:paddingBottom="24dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/diagnosticView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#DD111111"
        android:paddingStart="24dp"
        android:paddingTop="54dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

    <include layout="@layout/kiosk_settings_overlay" />
</FrameLayout>
